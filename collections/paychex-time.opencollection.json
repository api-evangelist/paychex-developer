{
  "opencollection": "1.0.0",
  "info": {
    "name": "Paychex Time API",
    "version": "1.0.0"
  },
  "request": {
    "auth": {
      "type": "oauth2",
      "flow": "client_credentials",
      "accessTokenUrl": "https://api.paychex.com/auth/oauth/v2/token",
      "credentials": {
        "clientId": "{{clientId}}",
        "clientSecret": "{{clientSecret}}"
      }
    }
  },
  "items": [
    {
      "info": {
        "name": "Time Entries",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Submit Time Entries",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.paychex.com/time/v1/timeentries",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Submit one or more time entries (worked hours, earnings categories, and labor allocations) for workers inside a Paychex Flex company."
        }
      ]
    }
  ],
  "bundled": true
}